# Copy to terraform.tfvars and fill in the values that apply.

project = "tasker-487819"
region  = "us-central1"

# Required: Google OAuth 2.0 Web Client ID. The application validates ID
# tokens against this audience for /ipam/* requests.
oauth_web_client_id = "REPLACE-WITH-YOUR-CLIENT-ID.apps.googleusercontent.com"

# Optional but recommended: gate /ipam/* by email.
# allowed_emails = ["you@gmail.com"]

# Set to true once you're ready to expose the service to Cloudflare / the
# public internet. App-layer auth still gates /ipam/*; calc/visualizer remain
# public on purpose.
# enable_public_invoker = true

# Cloudflare DNS — Path B (default): CNAME points at Cloud Run's default
# URL. No GCP-side domain mapping, no Search Console verification.
# Cloudflare proxy must be on (default). Set the zone ID and an API token
# scoped Zone:DNS:Edit on the target zone. Leave cloudflare_zone_id empty
# to skip Cloudflare entirely.
# cloudflare_zone_id   = "REPLACE-WITH-ZONE-ID"
# cloudflare_subdomain = "netcidr-v2"
# cloudflare_proxied   = true
# cloudflare_api_token = "REPLACE-WITH-TOKEN"   # set as a SECRET in Spacelift, never in this file

# Path A — flip these on if you want the canonical Cloud Run legacy
# domain mapping (GCP issues the cert; caller must be a verified owner
# of the domain in Search Console — see README).
# use_cloud_run_domain_mapping = true
# custom_domain                = "netcidr-v2.cloudreaper.dev"
