# Cloudflare API config for the DNS sync recipe (`just cloudflare-sync`).
# Copy to .env and fill in. .env is gitignored.

# Token must have `Zone:DNS:Edit` on the target zone.
CLOUDFLARE_API_TOKEN=

# Zone ID from the Cloudflare dashboard (zone overview page).
CLOUDFLARE_ZONE_ID=

# Hostname (relative to the zone — e.g., `netcidr` for netcidr.example.com).
CLOUDFLARE_RECORD_NAME=netcidr

# Cloudflare proxy mode. Must be `false` (gray cloud / DNS only) — the
# stack provisions an ACM cert covering the public hostname and CloudFront
# terminates TLS directly. Cloudflare's proxy can't rewrite the Host
# header on the free plan, so a proxied path would 403 at CloudFront.
CLOUDFLARE_PROXIED=false

# CloudFormation stack name (must match samconfig.toml).
SAM_STACK_NAME=netcidr
AWS_REGION=us-east-2

# Google OAuth Web Client ID — must match samconfig.toml's OidcAudience.
# Vite bakes this into the dashboard bundle at build time. Without it,
# the dashboard renders /ipam with a generic "Unauthorized" banner instead
# of the Google sign-in card. Use `op://...` reference here; it's the
# same value as OidcAudience in samconfig.toml.tpl.
VITE_OAUTH_WEB_CLIENT_ID=
