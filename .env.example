# Copy to `.env` and edit. `.env` is gitignored; `.env.example` is committed
# as the documentation of available options.

# Enable the Slack notifier Cloud Run Function.
# When true: `just bootstrap` also enables Cloud Functions/Eventarc/Secret
# Manager APIs + creates the cloud-builds Pub/Sub topic; `setup-slack` and
# `deploy-notifier` become usable.
# When false: Slack-related recipes refuse to run and bootstrap stays minimal.
NETCIDR_NOTIFIER=false

# Enable weekly automatic rebuild from latest upstream netcidr release.
# When true: `just bootstrap` enables Cloud Scheduler API + grants the
# compute SA builds.editor; `setup-autobuild` / `fire-rebuild` /
# `destroy-autobuild` become usable. Requires a Cloud Build GitHub
# connection (one-time, via Console).
NETCIDR_AUTOBUILD=false
